{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@i18n/*": ["src/shared/i18n/*"],
      "@auth/*": ["src/features/auth/*"],
      "@addProperty/*": ["src/features/add-property/*"],
      "@chat/*": ["src/features/chat/*"],
      "@daysPicker/*": ["src/features/day-picker/*"],
      "@favorites/*": ["src/features/favorites/*"],
      "@translation/*": ["src/features/translation/*"],
      "@currency/*": ["src/features/currency/*"],
      "@search/*": ["src/features/search/*"],
      "@properties/*": ["src/features/properties/*"],
      "@navigation/*": ["src/widgets/navigation/*"],
      "@sharedUI/*": ["src/shared/ui/*"],
      "@errors/*": ["src/shared/errors/*"],
      "@api/*": ["src/shared/api/*"],
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
